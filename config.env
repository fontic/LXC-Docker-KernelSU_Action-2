CONFIG_ENV=config.env
KERNEL_SOURCE=https://github.com/kutemeikito/android_kernel_xiaomi_ginkgo
KERNEL_SOURCE_BRANCH=sixteen
KERNEL_CONFIG=vendor/ginkgo-perf_defconfig
KERNEL_IMAGE_NAME=Image.gz-dtb
ARCH=arm64
EXTRA_CMDS:LLVM=1 LLVM_IAS=1
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-

ENABLE_KERNELSU=false
ENABLE_KPROBES=false
ENABLE_DOCKER_LXC=true
